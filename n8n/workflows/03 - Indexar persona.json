        "query": "SELECT id, primer_nombre, segundo_nombre, apellidos, tipo_documento, nro_documento, fecha_nacimiento, genero, correo, celular, foto_path\nFROM persona\nWHERE id = {{ $('Webhook').item.json.body.persona_id }};",
