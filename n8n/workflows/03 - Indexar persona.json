    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const p = $input.item.json;\nconst nombre = [p.primer_nombre, p.segundo_nombre, p.apellidos].filter(Boolean).join(' ');\nconst contenido = `${nombre}, ${p.tipo_documento} ${p.nro_documento}, nacido el ${p.fecha_nacimiento}, genero ${p.genero}, correo ${p.correo}, celular ${p.celular}.`;\nreturn { persona_id: p.id, contenido };"
      },
      "type": "n8n-nodes-base.code",
