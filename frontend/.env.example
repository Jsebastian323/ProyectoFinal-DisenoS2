# Variables de entorno del frontend (Vite las inyecta en build/dev).
# Copiar a frontend/.env y completar.

# URL del webhook del Chat Trigger del workflow "02 - Chat RAG" de n8n.
# Cada miembro del equipo tiene su propio webhookId al importar el workflow.
# Para obtenerlo: en n8n abrir workflow 02, click en el nodo "When chat
# message received", activar "Make Chat Publicly Available", clic "Open chat"
# y copiar la URL de la pestaña que se abre (es la production URL).
VITE_CHAT_WEBHOOK_URL=http://localhost:5678/webhook/<tu-webhook-id>/chat
